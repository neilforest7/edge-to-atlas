{
  "manifest_version": 3,
  "name": "Open in Paired Browser",
  "version": "0.1.0",
  "key": "",
  "description": "Open the current tab in the paired Edge or ChatGPT Atlas browser.",
  "action": {
    "default_title": "Open in paired browser"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "nativeMessaging"
  ]
}
